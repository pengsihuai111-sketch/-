# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=question_bank_v4

# JWT配置
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# AI模型配置（必需）
# Doubao API密钥（主要文本模型）
DOUBAO_API_KEY=your-doubao-api-key-here
DOUBAO_API_URL=https://api.newcoin.tech/v1/chat/completions
DOUBAO_MODEL=doubao-seed-1-6-251015

# Vision API密钥（图像识别）
VISION_API_KEY=your-vision-api-key-here
VISION_API_URL=https://api.newcoin.tech/v1/chat/completions
VISION_MODEL=doubao-seed-1-6-vision-250815

# DeepSeek配置（可选，备选文本模型）
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
# DEEPSEEK_MODEL=deepseek-chat

# 文本模型提供商选择: doubao 或 deepseek
TEXT_LLM_PROVIDER=doubao

# CORS配置（前端允许的源）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
