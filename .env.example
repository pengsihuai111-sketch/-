# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=question_bank_v4

# JWT Configuration
JWT_SECRET=change_me_to_a_random_secret

# DeepSeek API (Optional - backup text model)
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Text LLM Configuration (Primary)
DOUBAO_API_KEY=
DOUBAO_API_URL=https://api.newcoin.tech/v1/chat/completions
DOUBAO_MODEL=doubao-seed-1-6-251015

# Vision/OCR API Configuration
VISION_API_KEY=
VISION_API_URL=https://api.newcoin.tech/v1/chat/completions
VISION_MODEL=doubao-seed-1-6-vision-250815

# LLM Provider Selection (doubao or deepseek)
TEXT_LLM_PROVIDER=doubao
